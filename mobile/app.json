{
  "expo": {
    "name": "HeyBobo",
    "slug": "heybobo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "heybobo",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.heybobo.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for live workout pose detection and grooming visual analysis",
        "NSPhotoLibraryUsageDescription": "Used to upload profile photos and lesson resources",
        "NSBluetoothAlwaysUsageDescription": "Used to connect to fitness wearable devices",
        "NSBluetoothPeripheralUsageDescription": "Used to pair with heart rate monitors and fitness trackers",
        "NSMotionUsageDescription": "Used to track steps and physical activity",
        "NSMicrophoneUsageDescription": "Used for voice input in AI Tutor"
      },
      "associatedDomains": [
        "applinks:app.heybobo.ai"
      ]
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#6366F1"
      },
      "package": "com.heybobo.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.heybobo.ai",
              "pathPrefix": "/app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow HeyBobo to access your camera"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow HeyBobo to access your photos"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/notification-icon.png",
          "color": "#6366F1"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "a83ee5aa-c126-4b0e-9e8b-ec9c3e5197c3"
      }
    },
    "owner": "kaleshcv"
  }
}
